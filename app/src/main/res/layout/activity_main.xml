<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F1F8E9"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🐄 Gokula-Health"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:gravity="center"
        android:paddingTop="40dp"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Digital Health Card for Cattle"
        android:textSize="14sp"
        android:textColor="#666666"
        android:gravity="center"
        android:paddingBottom="40dp"/>

    <Button
        android:id="@+id/btnCattleProfile"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="🐮  Cattle Profile"
        android:textSize="18sp"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnMilkDiary"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="🥛  Milk Diary"
        android:textSize="18sp"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnVaccination"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="💉  Vaccination Alerts"
        android:textSize="18sp"
        android:backgroundTint="#FF5722"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnYieldGraph"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="📊  Yield Graph"
        android:textSize="18sp"
        android:backgroundTint="#9C27B0"/>
    <Button
        android:id="@+id/btnHeatCycle"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="🌡️  Heat Cycle Tracker"
        android:textSize="18sp"
        android:backgroundTint="#FF6F00"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnHealthPassport"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="📋  Health Passport"
        android:textSize="18sp"
        android:backgroundTint="#1B5E20"/>

</LinearLayout>